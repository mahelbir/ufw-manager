#!/usr/bin/env bash
set -euo pipefail

# If our mount namespace matches PID 1's we're already on the host, so call
# ufw directly. Otherwise hop into PID 1's namespaces via nsenter (the Docker
# container case, where this script is the only thing in the image).
detect_host_ufw() {
  local host_ns self_ns
  host_ns=$(readlink /proc/1/ns/mnt 2>/dev/null || true)
  self_ns=$(readlink /proc/self/ns/mnt 2>/dev/null || true)
  if [[ -n "$host_ns" && "$host_ns" == "$self_ns" ]]; then
    HOST_UFW=(ufw)
  else
    HOST_UFW=(nsenter -t 1 -m -u -i -n -p -- ufw)
  fi
}

HOST_UFW=()
detect_host_ufw

# Route mode toggle. When "on", rule commands are prefixed with `route` so
# they affect the FORWARD chain (Docker / published-port traffic). When "off",
# rule commands go to ufw unchanged (INPUT chain). Overridable via env var.
ROUTE_MODE="${UFW_ROUTE_MODE:-on}"

# Template dir. Priority: $UFW_TEMPLATES_DIR > script-relative ./templates
# (repo / dev checkout) > /usr/local/share/ufw-manager/templates (Docker image
# and installed standalone). Each tree holds custom/ (user, volume-mounted in
# Docker) and default/ (shipped with the repo) subfolders.
detect_templates_dir() {
  TEMPLATES_DIR="${UFW_TEMPLATES_DIR:-}"
  [[ -n "$TEMPLATES_DIR" ]] && return
  local script_dir
  script_dir="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
  if [[ -d "$script_dir/templates" ]]; then
    TEMPLATES_DIR="$script_dir/templates"
  else
    TEMPLATES_DIR="/usr/local/share/ufw-manager/templates"
  fi
}

TEMPLATES_DIR=""
detect_templates_dir

usage() {
  cat <<'EOF'
ufw-manager — host UFW wrapper. Extras on top of normal ufw:

  allow                    interactive wizard
  deny                     interactive wizard
  delete                   interactive wizard

  route-mode [on|off|toggle|status]
                           toggle whether rule commands are prefixed with
                           `route`. Default: on. Env: UFW_ROUTE_MODE.

  list                     alias for `status numbered`
  shell                    interactive REPL
  help                     help message

  <name> [args...]         run template <name>.tpl

Anything else is passed through to host ufw as-is (with the route prefix
injected for rule commands when route-mode is on).
EOF
}

run_ufw() {
  "${HOST_UFW[@]}" "$@"
}

# Runs a rule command, honoring ROUTE_MODE: prepends `route` when enabled.
run_rule() {
  if [[ "$ROUTE_MODE" == "on" ]]; then
    echo "-> ufw route $*"
    run_ufw route "$@"
  else
    echo "-> ufw $*"
    run_ufw "$@"
  fi
}

cmd_route_mode() {
  local sub="${1:-status}"
  case "$sub" in
    on)
      ROUTE_MODE="on"
      echo "route-mode: on"
      ;;
    off)
      ROUTE_MODE="off"
      echo "route-mode: off"
      ;;
    toggle)
      if [[ "$ROUTE_MODE" == "on" ]]; then
        ROUTE_MODE="off"
      else
        ROUTE_MODE="on"
      fi
      echo "route-mode: $ROUTE_MODE"
      ;;
    status|"")
      echo "route-mode: $ROUTE_MODE"
      ;;
    *)
      echo "error: unknown route-mode arg '$sub' (on/off/toggle/status)" >&2
      return 1
      ;;
  esac
}

wizard_rule() {
  local action="$1"
  local port="${2:-}" ip="${3:-}" proto="${4:-}"
  local ans

  if [[ -n "$port" ]]; then
    echo "Port: $port"
  else
    read -r -p "Port (e.g. 5432 or 5000:5010): " port
  fi
  if [[ -z "$port" ]]; then
    echo "cancelled: port is required" >&2
    return 1
  fi

  if [[ -n "$ip" ]]; then
    echo "IP/CIDR: $ip"
  else
    read -r -p "IP/CIDR (empty = any): " ip
  fi
  [[ -z "$ip" ]] && ip="any"

  if [[ -n "$proto" ]]; then
    echo "Protocol: $proto"
  else
    read -r -p "Protocol [tcp/udp/both] (default: both): " proto
    proto="${proto:-both}"
  fi
  case "$proto" in
    tcp|udp|both) ;;
    *)
      echo "cancelled: invalid protocol '$proto' (tcp/udp/both)" >&2
      return 1
      ;;
  esac

  local protos=()
  if [[ "$proto" == "both" ]]; then
    protos=(tcp udp)
  else
    protos=("$proto")
  fi

  local route_word=""
  [[ "$ROUTE_MODE" == "on" ]] && route_word="route "

  echo
  echo "commands to run:"
  local p
  for p in "${protos[@]}"; do
    echo "  ufw ${route_word}${action} proto $p from $ip to any port $port"
  done
  echo
  read -r -p "proceed? [Y/n]: " ans
  if [[ "$ans" == "n" || "$ans" == "N" ]]; then
    echo "cancelled."
    return 0
  fi

  local failed=0
  for p in "${protos[@]}"; do
    if ! run_rule "$action" proto "$p" from "$ip" to any port "$port"; then
      echo "error: failed to add $p rule" >&2
      failed=1
    fi
  done
  return $failed
}

wizard_delete() {
  echo "current rules:"
  run_ufw status numbered
  echo
  local raw
  read -r -p "rule number(s) to delete (space or comma separated): " raw
  raw="${raw//,/ }"
  # shellcheck disable=SC2206
  local nums=($raw)

  if (( ${#nums[@]} == 0 )); then
    echo "error: at least one number required" >&2
    return 1
  fi

  local n
  for n in "${nums[@]}"; do
    if [[ ! "$n" =~ ^[0-9]+$ ]]; then
      echo "error: invalid number '$n'" >&2
      return 1
    fi
  done

  # Dedupe and sort descending so earlier deletes don't shift later indices.
  local sorted
  sorted=$(printf '%s\n' "${nums[@]}" | sort -un | sort -rn)
  # shellcheck disable=SC2206
  local ordered=($sorted)

  echo "rules to delete (high to low): ${ordered[*]}"
  local ans
  read -r -p "proceed? [y/N]: " ans
  if [[ "$ans" != "y" && "$ans" != "Y" ]]; then
    echo "cancelled."
    return 0
  fi

  local failed=0
  for n in "${ordered[@]}"; do
    echo "-> ufw delete $n"
    if ! echo "y" | run_ufw delete "$n"; then
      echo "error: failed to delete #$n" >&2
      failed=1
    fi
  done
  return $failed
}

# Finds a template by bare name (no .tpl suffix). Searches custom/ before
# default/ and walks each tree up to 10 levels deep. Prints the first hit on
# stdout and returns 0; returns 1 if nothing matched.
template_find() {
  local name="$1" base sub hit
  for sub in custom default; do
    base="$TEMPLATES_DIR/$sub"
    [[ -d "$base" ]] || continue
    hit=$(find "$base" -maxdepth 10 -type f -name "${name}.tpl" 2>/dev/null | head -n 1 || true)
    if [[ -n "$hit" ]]; then
      printf '%s\n' "$hit"
      return 0
    fi
  done
  return 1
}

# Parses a template file and runs wizard_rule with the template's values.
# Template format (one rule line + optional placeholder assignments):
#   action:port:ip:proto         where action is allow|deny|reject|limit and
#                                any field may be `$N` as a placeholder
#   $N=<shell command>           fallback used if $N isn't passed on argv
#   # comment                    ignored
# Placeholder resolution order: argv[N] > `$N=` shell output > empty (wizard
# then prompts for that field).
template_run() {
  local file="$1"; shift
  local argv=("$@")
  local line rule="" action port ip proto
  # Parallel arrays instead of `declare -A` so this stays portable back to
  # bash 3.2 . Lookups are O(n) but N is the number of
  # placeholders in one template — effectively tiny.
  local assign_idx=() assign_val=()

  while IFS= read -r line || [[ -n "$line" ]]; do
    line="${line#"${line%%[![:space:]]*}"}"
    line="${line%"${line##*[![:space:]]}"}"
    [[ -z "$line" || "$line" == \#* ]] && continue
    if [[ "$line" =~ ^\$([0-9]+)=(.*)$ ]]; then
      assign_idx+=("${BASH_REMATCH[1]}")
      assign_val+=("${BASH_REMATCH[2]}")
    elif [[ -z "$rule" ]]; then
      rule="$line"
    fi
  done < "$file"

  if [[ -z "$rule" ]]; then
    echo "error: template '$file' has no rule line" >&2
    return 1
  fi

  IFS=':' read -r action port ip proto <<< "$rule"
  if [[ -z "${action:-}" || -z "${port:-}" || -z "${ip:-}" || -z "${proto:-}" ]]; then
    echo "error: template '$file' malformed (expected action:port:ip:proto)" >&2
    return 1
  fi
  case "$action" in
    allow|deny|reject|limit) ;;
    *)
      echo "error: template '$file' has invalid action '$action'" >&2
      return 1
      ;;
  esac

  local field val idx cmd out i
  for field in port ip proto; do
    val="${!field}"
    if [[ "$val" =~ ^\$([0-9]+)$ ]]; then
      idx="${BASH_REMATCH[1]}"
      val="${argv[$((idx-1))]:-}"
      if [[ -z "$val" ]]; then
        cmd=""
        for ((i=0; i<${#assign_idx[@]}; i++)); do
          if [[ "${assign_idx[$i]}" == "$idx" ]]; then
            cmd="${assign_val[$i]}"
            break
          fi
        done
        if [[ -n "$cmd" ]]; then
          if out=$(bash -c "$cmd" 2>/dev/null); then
            out="${out//$'\r'/}"
            out="${out//$'\n'/}"
            val="$out"
          else
            echo "warning: \$${idx} command failed: $cmd" >&2
            val=""
          fi
        fi
      fi
      printf -v "$field" '%s' "$val"
    fi
  done

  echo "template: $file"
  wizard_rule "$action" "$port" "$ip" "$proto"
}

dispatch() {
  local sub="${1:-shell}"
  shift || true
  case "$sub" in
    allow|deny)
      if (( $# == 0 )); then
        wizard_rule "$sub"
      else
        run_rule "$sub" "$@"
      fi
      ;;
    delete|del)
      if (( $# == 0 )); then
        wizard_delete
      elif (( $# == 1 )) && [[ "$1" =~ ^[0-9]+$ ]]; then
        echo "-> ufw delete $1"
        run_ufw delete "$1"
      else
        run_rule delete "$@"
      fi
      ;;
    reject|limit|insert)
      run_rule "$sub" "$@"
      ;;
    route-mode|routemode|mode)
      cmd_route_mode "$@"
      ;;
    list|ls)
      run_ufw status numbered
      ;;
    shell)
      run_shell
      ;;
    help|-h|--help)
      usage
      ;;
    *)
      local tfile
      if tfile=$(template_find "$sub"); then
        template_run "$tfile" "$@"
      else
        run_ufw "$sub" "$@"
      fi
      ;;
  esac
}

run_shell() {
  echo "ufw-manager interactive mode. type 'help' for commands, 'exit' to quit."
  echo "route-mode: $ROUTE_MODE (toggle with: route-mode on|off|toggle)"
  local line prompt
  while true; do
    prompt="ufw[${ROUTE_MODE}]> "
    read -r -e -p "$prompt" line || { echo; break; }
    [[ -z "$line" ]] && continue
    if [[ "$line" == "exit" || "$line" == "quit" ]]; then
      break
    fi
    set +e
    # shellcheck disable=SC2086
    dispatch $line
    set -e
  done
}

dispatch "$@"
